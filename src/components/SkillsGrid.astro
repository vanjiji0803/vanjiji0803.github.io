---
<section id="skills" class="section">
  <div class="section-inner">
    <p class="section-label">
      <span class="lang-en">05 — Skills</span>
      <span class="lang-zh">05 — 技能</span>
    </p>
    <div class="skills-grid">
      {skills.map((s) => (
        <div class="skill-card reveal">
          <h4><span class="lang-en">{s.title.en}</span><span class="lang-zh">{s.title.zh}</span></h4>
          <p class="lang-en">{s.body.en}</p>
          <p class="lang-zh">{s.body.zh}</p>
        </div>
      ))}
    </div>
  </div>
</section>
